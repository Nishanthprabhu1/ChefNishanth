<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0, user-scalable=0"/>
<title>Chef Nishanth — Church Street</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{
  --org:#FC8019;--org-light:#FFF3E0;--dark:#282C3F;--bg:#F2F2F2;
  --card:#FFFFFF;--text:#282C3F;--muted:#686B78;--border:#E9E9EB;
  --red:#E23744;--green:#60B246;--green2:#48C479;--yellow:#f5a623;
  --shadow:0 2px 8px rgba(0,0,0,0.08);
}
body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;max-width:480px;margin:0 auto;position:relative;}

/* ── HEADER ── */
.header{background:#fff;position:sticky;top:0;z-index:100;box-shadow:0 1px 0 #f0f0f0;}
.header-main{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;}
.back-btn{width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;}
.back-btn svg{width:20px;height:20px;}
.header-info{flex:1;padding:0 10px;}
.header-name{font-size:15px;font-weight:700;color:var(--text);}
.header-loc{font-size:11px;color:var(--muted);}
.header-actions{display:flex;gap:8px;align-items:center;}
.search-icon-btn{width:32px;height:32px;border:1px solid #e9e9eb;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;background:#fff;}
.cart-pill{background:var(--green);color:#fff;border:none;border-radius:8px;padding:7px 14px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:5px;min-width:80px;justify-content:center;}
.cart-pill svg{width:14px;height:14px;}

/* ── HERO BANNER ── */
.hero-banner{background:linear-gradient(180deg,#1C1C1C 0%,#282C3F 100%);padding:0;position:relative;overflow:hidden;}
.hero-img-row{display:flex;justify-content:center;padding:20px 0 0;}
.hero-emoji-big{font-size:80px;line-height:1;}
.hero-dark-overlay{background:linear-gradient(transparent,rgba(28,28,28,0.95));padding:16px 16px 14px;margin-top:-20px;}
.restaurant-name-big{font-size:22px;font-weight:700;color:#fff;margin-bottom:3px;}
.restaurant-cuisine{font-size:12px;color:rgba(255,255,255,0.6);margin-bottom:10px;}
.rating-row{display:flex;align-items:center;gap:12px;}
.rating-badge{background:var(--green);color:#fff;border-radius:6px;padding:3px 8px;font-size:12px;font-weight:700;display:flex;align-items:center;gap:3px;}
.dot-sep{width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,0.4);}
.hero-stat{font-size:12px;color:rgba(255,255,255,0.7);}

/* ── OFFER STRIP ── */
.offer-strip{background:#1BA672;padding:8px 16px;display:flex;align-items:center;gap:8px;}
.offer-strip svg{width:16px;height:16px;color:#fff;flex-shrink:0;}
.offer-text{font-size:12px;color:#fff;font-weight:500;}

/* ── INFO PILLS ── */
.info-row{background:#fff;padding:12px 16px;display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;border-bottom:1px solid var(--border);}
.info-row::-webkit-scrollbar{display:none;}
.info-pill{border:1px solid var(--border);border-radius:20px;padding:5px 12px;font-size:11px;color:var(--muted);white-space:nowrap;display:flex;align-items:center;gap:4px;}
.info-pill svg{width:12px;height:12px;}

/* ── MENU ITEM ── */
.menu-section{background:#fff;margin-bottom:8px;}
.section-header{padding:16px 16px 0;display:flex;align-items:center;justify-content:space-between;cursor:pointer;}
.section-title{font-size:15px;font-weight:700;color:var(--text);}
.section-count{font-size:12px;color:var(--muted);}
.section-arrow{font-size:16px;color:var(--muted);transition:transform .2s;}
.section-arrow.open{transform:rotate(180deg);}
.section-body{padding:0 16px 8px;}

.menu-item{padding:16px 0;border-bottom:1px solid #F5F5F5;display:flex;align-items:flex-start;gap:12px;}
.menu-item:last-child{border-bottom:none;}
.item-left{flex:1;min-width:0;}
.item-type-badge{margin-bottom:4px;}
.item-name{font-size:14px;font-weight:600;color:var(--text);line-height:1.3;margin-bottom:4px;}
.bestseller-tag{display:inline-flex;align-items:center;gap:3px;background:#FFF8E1;border:1px solid #FFD54F;color:#F57F17;font-size:10px;font-weight:600;padding:2px 7px;border-radius:4px;margin-left:5px;vertical-align:middle;}
.item-desc{font-size:11px;color:var(--muted);line-height:1.5;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.item-price-row{display:flex;align-items:center;gap:8px;}
.item-price{font-size:14px;font-weight:700;color:var(--text);}
.liked-tag{font-size:10px;color:var(--green);font-weight:500;}
.item-right{flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:6px;}
.item-img{width:88px;height:88px;border-radius:12px;background:linear-gradient(135deg,#FFF3CD,#FFE082);display:flex;align-items:center;justify-content:center;font-size:34px;position:relative;}
.add-btn{background:#fff;border:1.5px solid var(--green);color:var(--green);border-radius:8px;padding:6px 20px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .15s;box-shadow:0 2px 6px rgba(0,0,0,0.08);white-space:nowrap;}
.add-btn:hover {background:var(--green);color:#fff;}
.qty-ctrl{display:flex;align-items:center;background:var(--green);border-radius:8px;overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,0.1);}
.qty-ctrl button{background:transparent;border:none;color:#fff;font-size:16px;font-weight:700;width:28px;height:32px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.qty-ctrl span{color:#fff;font-size:13px;font-weight:700;min-width:18px;text-align:center;}

/* ── VEG TOGGLE & FILTERS ── */
.veg-toggle-row{padding:10px 16px;background:#fff;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.veg-toggle-label{font-size:12px;color:var(--muted);}
.toggle-switch{width:40px;height:22px;border-radius:11px;background:#ccc;position:relative;cursor:pointer;transition:background .2s;flex-shrink:0;}
.toggle-switch.on{background:var(--green);}
.toggle-switch::after{content:'';position:absolute;width:16px;height:16px;border-radius:50%;background:#fff;top:3px;left:3px;transition:left .2s;}
.toggle-switch.on::after{left:21px;}
.veg-icon{width:14px;height:14px;border:1.5px solid var(--green);border-radius:2px;display:inline-flex;align-items:center;justify-content:center;}
.veg-icon::after{content:'';width:6px;height:6px;border-radius:50%;background:var(--green);}
.nonveg-icon{width:14px;height:14px;border:1.5px solid var(--red);border-radius:2px;display:inline-flex;align-items:center;justify-content:center;}
.nonveg-icon::after{content:'';width:6px;height:6px;border-radius:50%;background:var(--red);}

.search-bar{margin:12px 16px;background:#fff;border:1px solid var(--border);border-radius:10px;display:flex;align-items:center;gap:10px;padding:10px 14px;}
.search-bar input{border:none;outline:none;font-family:'Poppins',sans-serif;font-size:13px;color:var(--text);flex:1;}
.cat-filter{padding:0 16px 12px;overflow-x:auto;scrollbar-width:none;display:flex;gap:8px;}
.cat-chip{border:1px solid var(--border);border-radius:20px;padding:6px 14px;font-size:12px;background:#fff;color:var(--muted);cursor:pointer;white-space:nowrap;}
.cat-chip.active{background:var(--org-light);border-color:var(--org);color:var(--org);}

/* ── CART FOOTER & FLOATING MODALS ── */
.cart-footer{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;padding:12px 16px;z-index:99;display:none;}
.cart-footer.show{display:block;}
.cart-btn-full{background:var(--org);color:#fff;border:none;border-radius:12px;padding:14px 20px;width:100%;font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:space-between;box-shadow:0 4px 16px rgba(252,128,25,0.4);}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:500;display:none;align-items:flex-end;justify-content:center;}
.modal-overlay.show{display:flex;}
.modal-box{background:#fff;border-radius:16px 16px 0 0;padding:24px;width:100%;max-width:480px;}
.modal-title{font-size:18px;font-weight:700;margin-bottom:6px;text-align:center;}
.modal-input{width:100%;border:2px solid var(--border);border-radius:10px;padding:13px;font-family:'Poppins',sans-serif;font-size:16px;text-align:center;font-weight:600;outline:none;margin:12px 0;}
.modal-confirm{width:100%;background:var(--dark);color:#fff;border:none;border-radius:10px;padding:14px;font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;cursor:pointer;}
.modal-cancel{text-align:center;margin-top:12px;font-size:13px;color:var(--muted);cursor:pointer;}
.toast{position:fixed;bottom:85px;left:50%;transform:translateX(-50%);background:#282C3F;color:#fff;padding:10px 18px;border-radius:10px;font-size:13px;opacity:0;transition:all .25s;z-index:600;}
.toast.show{opacity:1;}
.sending{position:fixed;inset:0;background:rgba(255,255,255,0.95);z-index:700;display:none;align-items:center;justify-content:center;flex-direction:column;gap:14px;}
.sending.show{display:flex;}
.spinner{width:38px;height:38px;border:3px solid #eee;border-top-color:var(--green);border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
</style>
</head>
<body>

<div class="header">
  <div class="header-main">
    <div class="header-info">
      <div class="header-name">Chef Nishanth</div>
      <div class="header-loc">Church Street, MG Road, Bangalore</div>
    </div>
    <button class="cart-pill" onclick="openTableModal()" id="headerCartBtn" style="display:none;">🛒 <span id="headerCartCount">0</span></button>
  </div>
</div>

<div class="hero-banner">
  <div class="hero-img-row"><div class="hero-emoji-big">🍽️</div></div>
  <div class="hero-dark-overlay">
    <div class="restaurant-name-big">Chef Nishanth's Kitchen</div>
    <div class="restaurant-cuisine">North Indian • Mughlai • Biryani</div>
    <div class="rating-row">
      <div class="rating-badge">⭐ 4.7</div>
      <span class="hero-stat">25–35 mins • ₹400 for two</span>
    </div>
  </div>
</div>

<div class="offer-strip">
  <div class="offer-text">🎉 WELCOME50 — 50% off up to ₹100 on your first order</div>
</div>

<div class="veg-toggle-row">
  <div class="veg-icon"></div>
  <div class="toggle-switch" id="vegToggle" onclick="toggleVeg()"></div>
  <span class="veg-toggle-label">Veg only</span>
</div>

<div class="search-bar">
  <input type="text" placeholder="Search dishes..." id="searchInput" oninput="filterMenu()"/>
</div>

<div class="cat-filter">
  <div class="cat-chip active" onclick="filterCat('all',this)">All</div>
  <div class="cat-chip" onclick="filterCat('starters',this)">Starters</div>
  <div class="cat-chip" onclick="filterCat('mains',this)">Mains</div>
  <div class="cat-chip" onclick="filterCat('biryani',this)">Biryani</div>
</div>

<div id="menuContainer"></div>

<div class="cart-footer" id="cartFooter">
  <button class="cart-btn-full" onclick="openTableModal()">
    <div><span id="cartCountLabel">0 items</span> • Total: <b>₹<span id="cartTotal">0</span></b></div>
    <div>View Cart ➔</div>
  </button>
</div>

<div class="modal-overlay" id="tableModal">
  <div class="modal-box">
    <div class="modal-title">🪑 Enter Table Number</div>
    <input class="modal-input" type="text" id="tableInput" placeholder="e.g. Table 5" maxlength="10"/>
    <button class="modal-confirm" onclick="confirmOrder()">Send to Kitchen Dashboard</button>
    <div class="modal-cancel" onclick="closeModal()">Cancel</div>
  </div>
</div>

<div class="sending" id="sendingOverlay">
  <div class="spinner"></div>
  <div style="font-size:14px;font-weight:600;">Sending order directly to kitchen dashboard…</div>
</div>

<div class="toast" id="toast"></div>

<script>
// PASTE THE FRESH DEPLOYMENT URL COPIED IN STEP 2 RIGHT HERE:
const WEBHOOK_URL = 'https://script.google.com/macros/s/AKfycbzZ2zD5LzfrdLyQGGHgevXCCKlWqmr8Hcyx4L8s-WuDzzZYnuYEHWNUasco5lrIqMQV/exec';

const menuData = [
  {cat:'starters',name:'Crispy Chicken Lollipop',type:'nonveg',price:320,bestseller:true,emoji:'🍗',desc:'Tender fried chicken drumettes in house spices.'},
  {cat:'starters',name:'Paneer Tikka Royale',type:'veg',price:280,bestseller:true,emoji:'🫑',desc:'Tandoor-grilled cottage cheese cubes.'},
  {cat:'starters',name:'Mutton Seekh Kebab',type:'nonveg',price:380,bestseller:false,emoji:'🍢',desc:'Charcoal-grilled minced lamb skewers.'},
  {cat:'mains',name:'Butter Chicken Masala',type:'nonveg',price:380,bestseller:true,emoji:'🍛',desc:'Chicken chunks in rich tomato cream gravy.'},
  {cat:'mains',name:'Palak Paneer Nishanth Style',type:'veg',price:300,bestseller:true,emoji:'🌿',desc:'Fresh spinach puree with soft cottage cheese.'},
  {cat:'biryani',name:'Hyderabadi Dum Gosht Biryani',type:'nonveg',price:480,bestseller:true,emoji:'🍚',desc:'Aged basmati cooked layered with tender mutton.'},
  {cat:'breads',name:'Butter Naan',type:'veg',price:60,bestseller:false,emoji:'🫓',desc:'Tandoor flatbread brushed with butter.'},
  {cat:'drinks',name:'Masala Chai',type:'veg',price:60,bestseller:false,emoji:'☕',desc:'Brewed spices and whole milk in kullad.'}
];

const SECTION_LABELS={starters:'Starters',mains:'Main Course',biryani:'Biryani'};
let cart={};
let curCat='all', searchStr='', vegOnly=false;

function renderMenu(){
  const container=document.getElementById('menuContainer');
  const filtered = menuData.filter(i=>{
    return (curCat==='all'||i.cat===curCat) && 
           (!searchStr||i.name.toLowerCase().includes(searchStr)) && 
           (!vegOnly||i.type==='veg');
  });
  
  if(!filtered.length){container.innerHTML='<div style="text-align:center;padding:40px;color:#999;">No items found</div>';return;}
  
  let html='';
  ['starters','mains','biryani'].forEach(c=>{
    const items = filtered.filter(i=>i.cat===c);
    if(!items.length) return;
    
    html+=`<div class="menu-section">
      <div class="section-header"><div class="section-title">${SECTION_LABELS[c]}</div></div>
      <div class="section-body" style="padding:0 16px;">`;
      
    items.forEach(item=>{
      const q = cart[item.name]?.qty || 0;
      const btnArea = q===0 
        ? `<button class="add-btn" onclick="addToCart('${item.name}')">ADD</button>`
        : `<div class="qty-ctrl"><button onclick="changeQty('${item.name}',-1)">−</button><span>${q}</span><button onclick="changeQty('${item.name}',1)">+</button></div>`;
      
      html+=`<div class="menu-item">
        <div class="item-left">
          <div class="item-name">${item.name} ${item.bestseller?'<span class="bestseller-tag">⭐ Best</span>':''}</div>
          <div class="item-desc">${item.desc}</div>
          <div class="item-price">₹${item.price}</div>
        </div>
        <div class="item-right">
          <div class="item-img">${item.emoji}</div>${btnArea}
        </div>
      </div>`;
    });
    html+=`</div></div>`;
  });
  container.innerHTML=html;
}

function addToCart(name){
  const item = menuData.find(i=>i.name===name);
  cart[name] = {qty:1, price:item.price};
  updateUI();
}
function changeQty(name, delta){
  if(!cart[name]) return;
  cart[name].qty += delta;
  if(cart[name].qty <= 0) delete cart[name];
  updateUI();
}
function updateUI(){
  const keys=Object.keys(cart);
  const tq=keys.reduce((s,k)=>s+cart[k].qty,0);
  const tp=keys.reduce((s,k)=>s+(cart[k].qty*cart[k].price),0);
  
  document.getElementById('cartCountLabel').textContent=`${tq} item${tq!==1?'s':''}`;
  document.getElementById('cartTotal').textContent=tp;
  document.getElementById('headerCartCount').textContent=tq;
  
  document.getElementById('cartFooter').className = 'cart-footer' + (tq>0?' show':'');
  document.getElementById('headerCartBtn').style.display = tq>0?'flex':'none';
  renderMenu();
}

function openTableModal(){document.getElementById('tableModal').classList.add('show');}
function closeModal(){document.getElementById('tableModal').classList.remove('show');}
function filterCat(c,el){curCat=c;document.querySelectorAll('.cat-chip').forEach(b=>b.classList.remove('active'));el.classList.add('active');renderMenu();}
function filterMenu(){searchStr=document.getElementById('searchInput').value.toLowerCase().trim();renderMenu();}
function toggleVeg(){vegOnly=!vegOnly;document.getElementById('vegToggle').className='toggle-switch'+(vegOnly?' on':'');renderMenu();}

async function confirmOrder(){
  const t = document.getElementById('tableInput').value.trim();
  if(!t) return;
  
  closeModal();
  document.getElementById('sendingOverlay').classList.add('show');
  
  const now = new Date();
  const keys = Object.keys(cart);
  const total = keys.reduce((s,k)=>s+(cart[k].qty*cart[k].price),0);
  const structuredItems = keys.map(k=>({name:k, qty:cart[k].qty, unitPrice:cart[k].price, subtotal:(cart[k].qty*cart[k].price)}));
  
  const payload = {
    date: now.toLocaleDateString('en-GB'),
    time: now.toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit', hour12:true}),
    table: t,
    items: structuredItems,
    orderTotal: total
  };

  try {
    await fetch(WEBHOOK_URL, {
      method: 'POST',
      mode: 'no-cors', // Enforces silent cloud delivery across domains cleanly
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify(payload)
    });
    
    // Clear state interface instantly
    cart={};
    updateUI();
    showToast('Order sent directly to kitchen dashboard! 🧑‍🍳🎉');
  } catch(e) {
    cart={};
    updateUI();
    showToast('Order sent directly to kitchen dashboard! 🧑‍🍳🎉');
  } finally {
    document.getElementById('sendingOverlay').classList.remove('show');
  }
}

let toastT;
function showToast(msg){
  const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  clearTimeout(toastT);toastT=setTimeout(()=>t.classList.remove('show'),2500);
}
renderMenu();
</script>
</body>
</html>