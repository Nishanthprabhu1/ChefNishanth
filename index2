const cart = {};
let currentCat = 'all';
let searchTerm = '';
let sheetItem = null, sheetQty = 1;
let sheetRadioSelections = {}, sheetAddonSelections = {};

function escKey(k){ return k.replace(/[^a-zA-Z0-9]/g,'_'); }

/* ── MENU RENDER ── */
function getFiltered(){
  return menuData.filter(item=>{
    const catMatch=currentCat==='all'||item.cat===currentCat;
    const sm=!searchTerm||item.name.toLowerCase().includes(searchTerm)||item.desc.toLowerCase().includes(searchTerm);
    return catMatch&&sm;
  });
}
function groupByCategory(items){
  const groups={},order=['starters','mains','biryani','breads','desserts','drinks'];
  const labels={starters:'Starters',mains:'Main Course',biryani:'Biryani',breads:'Breads & Rotis',desserts:'Desserts',drinks:'Beverages'};
  items.forEach(item=>{if(!groups[item.cat])groups[item.cat]=[];groups[item.cat].push(item);});
  return order.filter(c=>groups[c]).map(c=>({cat:c,label:labels[c],items:groups[c]}));
}
function renderMenu(){
  const filtered=getFiltered();
  const container=document.getElementById('menuContainer');
  if(!filtered.length){container.innerHTML='<div style="text-align:center;padding:60px 20px;color:#B0A090;"><div style="font-size:40px;margin-bottom:12px;">🔍</div><div style="font-size:15px;">No dishes found</div></div>';return;}
  const groups=currentCat==='all'?groupByCategory(filtered):[{cat:currentCat,label:'',items:filtered}];
  let html='';
  groups.forEach((group,gi)=>{
    if(gi>0)html+='<div class="divider"></div>';
    html+=`<div class="section" id="section-${group.cat}">`;
    if(group.label){html+=`<div class="section-title">${group.label}</div><div class="section-count">${group.items.length} item${group.items.length>1?'s':''}</div>`;}
    group.items.forEach(item=>{
      const qty=cart[item.name]?.totalQty||0,ek=escKey(item.name);
      const addArea=qty===0
        ?`<button class="add-btn" onclick="event.stopPropagation();openSheet('${ek}')">+ ADD</button>`
        :`<div class="qty-ctrl"><button onclick="event.stopPropagation();quickRemove('${ek}')">−</button><span>${qty}</span><button onclick="event.stopPropagation();openSheet('${ek}')">+</button></div>`;
      html+=`<div class="menu-card" onclick="openSheet('${ek}')">
        <div class="item-info">
          <div class="item-name"><span class="veg-dot ${item.type}"></span>${item.name}${item.bestseller?'<span class="bestseller">🏆 Bestseller</span>':''}</div>
          <div class="item-desc">${item.desc}</div>
          <div class="item-price"><span class="currency">₹</span>${item.price}</div>
        </div>
        <div class="item-img-wrap">
          <div class="item-img-placeholder" role="img" aria-label="${item.name}">${item.emoji}</div>
          ${addArea}
        </div>
      </div>`;
    });
    html+='</div>';
  });
  container.innerHTML=html;
}

/* ── BOTTOM SHEET ── */
function openSheet(ek){
  const item=menuData.find(i=>escKey(i.name)===ek);
  if(!item)return;
  sheetItem=item; sheetQty=1; sheetRadioSelections={}; sheetAddonSelections={};
  item.customGroups.forEach((g,gi)=>{if(g.type==='radio')sheetRadioSelections[gi]=0;});
  document.getElementById('sheetHero').innerHTML=`<span style="font-size:72px">${item.emoji}</span><div class="sheet-hero-badge"><span class="veg-dot ${item.type}" style="width:14px;height:14px;"></span></div>`;
  let html=`<div class="sheet-header"><div class="sheet-name-row"><div class="sheet-name">${item.name}</div><div class="sheet-price">₹${item.price}</div></div><div class="sheet-desc">${item.desc}</div></div>`;
  item.customGroups.forEach((g,gi)=>{
    html+=`<div class="cust-group"><div class="cust-group-title">${g.title}</div><div class="cust-group-sub">${g.sub}</div>`;
    g.options.forEach((opt,oi)=>{
      html+=`<div class="cust-row"><div class="cust-label">${opt.name}</div><div class="cust-right"><span class="cust-price">+${opt.extra.toFixed(2)}</span><div class="radio-btn${sheetRadioSelections[gi]===oi?' selected':''}" id="radio-${gi}-${oi}" onclick="selectRadio(${gi},${oi})"></div></div></div>`;
    });
    html+=`</div>`;
  });
  if(item.addons&&item.addons.length){
    html+=`<div class="cust-group"><div class="cust-group-title">Add-ons</div><div class="cust-group-sub">Optional extras</div>`;
    item.addons.forEach((ao,ai)=>{
      html+=`<div class="cust-row"><div style="display:flex;align-items:center;gap:10px;"><div class="check-btn${sheetAddonSelections[ai]?' selected':''}" id="check-${ai}" onclick="toggleAddon(${ai})"></div><div class="cust-label">${ao.name}</div></div><div class="cust-price">+ ${ao.extra.toFixed(2)}</div></div>`;
    });
    html+=`</div>`;
  }
  document.getElementById('sheetBody').innerHTML=html;
  document.getElementById('sheetQty').textContent=sheetQty;
  updateSheetTotal();
  document.getElementById('overlay').classList.add('show');
  document.getElementById('bottomSheet').classList.add('show');
  document.body.style.overflow='hidden';
}
function closeSheet(){
  document.getElementById('overlay').classList.remove('show');
  document.getElementById('bottomSheet').classList.remove('show');
  document.body.style.overflow='';
  sheetItem=null;
}
function selectRadio(gi,oi){
  sheetRadioSelections[gi]=oi;
  sheetItem.customGroups[gi].options.forEach((_,idx)=>{
    const el=document.getElementById(`radio-${gi}-${idx}`);
    if(el)el.className='radio-btn'+(idx===oi?' selected':'');
  });
  updateSheetTotal();
}
function toggleAddon(ai){
  sheetAddonSelections[ai]=!sheetAddonSelections[ai];
  const el=document.getElementById(`check-${ai}`);
  if(el)el.className='check-btn'+(sheetAddonSelections[ai]?' selected':'');
  updateSheetTotal();
}
function sheetQtyChange(delta){
  sheetQty=Math.max(1,sheetQty+delta);
  document.getElementById('sheetQty').textContent=sheetQty;
  updateSheetTotal();
}
function calcSheetItemPrice(){
  if(!sheetItem)return 0;
  let base=sheetItem.price;
  sheetItem.customGroups.forEach((g,gi)=>{if(g.type==='radio'&&sheetRadioSelections[gi]!=null)base+=g.options[sheetRadioSelections[gi]].extra;});
  if(sheetItem.addons)sheetItem.addons.forEach((ao,ai)=>{if(sheetAddonSelections[ai])base+=ao.extra;});
  return base;
}
function updateSheetTotal(){
  const total=calcSheetItemPrice()*sheetQty;
  document.getElementById('sheetAddBtn').textContent=`ADD TO CART — ₹${total.toLocaleString('en-IN')}`;
}
function addToCartFromSheet(){
  if(!sheetItem)return;
  const key=sheetItem.name,unitPrice=calcSheetItemPrice();
  if(!cart[key])cart[key]={item:sheetItem,totalQty:0,totalPrice:0,entries:[]};
  cart[key].totalQty+=sheetQty;
  cart[key].totalPrice+=unitPrice*sheetQty;
  cart[key].entries.push({qty:sheetQty,unitPrice});
  updateCartUI(); renderMenu(); closeSheet();
  showToast(`${sheetItem.name} added to cart`);
}
function quickRemove(ek){
  const item=menuData.find(i=>escKey(i.name)===ek);
  if(!item||!cart[item.name])return;
  const entry=cart[item.name].entries[cart[item.name].entries.length-1];
  if(!entry)return;
  cart[item.name].totalQty-=entry.qty;
  cart[item.name].totalPrice-=entry.unitPrice*entry.qty;
  cart[item.name].entries.pop();
  if(cart[item.name].totalQty<=0)delete cart[item.name];
  updateCartUI(); renderMenu();
}
function updateCartUI(){
  const keys=Object.keys(cart);
  const totalQty=keys.reduce((s,k)=>s+cart[k].totalQty,0);
  const totalPrice=keys.reduce((s,k)=>s+cart[k].totalPrice,0);
  document.getElementById('headerCount').textContent=totalQty;
  document.getElementById('cartItemsCount').textContent=`${totalQty} item${totalQty!==1?'s':''}`;
  document.getElementById('cartTotal').textContent=totalPrice.toLocaleString('en-IN');
  const footer=document.getElementById('cartFooter');
  if(totalQty>0)footer.classList.add('show');else footer.classList.remove('show');
}

/* ── TABLE MODAL ── */
function openTableModal(){
  const keys=Object.keys(cart);
  if(!keys.length){showToast('Your cart is empty!');return;}
  document.getElementById('tableNumberInput').value='';
  document.getElementById('tableModalOverlay').classList.add('show');
}
function closeTableModal(){
  document.getElementById('tableModalOverlay').classList.remove('show');
}

/* ── CONFIRM & SEND ORDER ── */
async function confirmOrder(){
  const tableRaw=document.getElementById('tableNumberInput').value.trim();
  if(!tableRaw){
    document.getElementById('tableNumberInput').focus();
    document.getElementById('tableNumberInput').style.borderColor='var(--red)';
    setTimeout(()=>document.getElementById('tableNumberInput').style.borderColor='',1500);
    return;
  }
  closeTableModal();
  document.getElementById('sendingOverlay').classList.add('show');

  const now=new Date();
  const dateStr=now.toLocaleDateString('en-IN',{day:'2-digit',month:'2-digit',year:'numeric'});
  const timeStr=now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true});
  const keys=Object.keys(cart);
  const orderTotal=keys.reduce((s,k)=>s+cart[k].totalPrice,0);

  // Build rows for Sheets (one row per item entry)
  const rows=[];
  keys.forEach(k=>{
    cart[k].entries.forEach(entry=>{
      rows.push({
        date:dateStr,
        time:timeStr,
        table:tableRaw,
        itemName:k,
        qty:entry.qty,
        unitPrice:entry.unitPrice,
        subtotal:entry.unitPrice*entry.qty,
        orderTotal:orderTotal
      });
    });
  });

  // Send to Google Sheets via Apps Script
  if(APPS_SCRIPT_URL && APPS_SCRIPT_URL !== 'YOUR_APPS_SCRIPT_URL_HERE'){
    try{
      await fetch(APPS_SCRIPT_URL,{
        method:'POST',
        mode:'no-cors',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({rows})
      });
    }catch(e){console.warn('Sheet logging failed:',e);}
  }

  // Build WhatsApp message
  let msg=`🍽️ *New Order — Chef Nishanth*\n`;
  msg+=`📍 *Table:* ${tableRaw}\n`;
  msg+=`🕐 *Time:* ${timeStr}\n`;
  msg+=`━━━━━━━━━━━━━━━━━━\n`;
  keys.forEach(k=>{
    cart[k].entries.forEach(entry=>{
      msg+=`▸ ${k} x${entry.qty} — ₹${(entry.unitPrice*entry.qty).toLocaleString('en-IN')}\n`;
    });
  });
  msg+=`━━━━━━━━━━━━━━━━━━\n`;
  msg+=`💰 *Total: ₹${orderTotal.toLocaleString('en-IN')}*`;

  setTimeout(()=>{
    document.getElementById('sendingOverlay').classList.remove('show');
    const waUrl=`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`;
    window.open(waUrl,'_blank');
    // Clear cart
    Object.keys(cart).forEach(k=>delete cart[k]);
    updateCartUI();
    renderMenu();
    showToast('Order sent via WhatsApp! 🎉');
  },800);
}

function filterCat(cat,el){
  currentCat=cat;
  document.querySelectorAll('.cat').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  renderMenu();
}
function filterMenu(){
  searchTerm=document.getElementById('searchInput').value.toLowerCase().trim();
  renderMenu();
}
let toastTimer;
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),2500);
}
document.querySelectorAll('.tab').forEach(tab=>{
  tab.addEventListener('click',function(){
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    this.classList.add('active');
  });
});
// Close table modal on backdrop click
document.getElementById('tableModalOverlay').addEventListener('click',function(e){if(e.target===this)closeTableModal();});

renderMenu();
