<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0, user-scalable=0"/>
<title>Chef Nishanth - Church Street</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  *{margin:0;padding:0;box-sizing:border-box;}
  :root{
    --gold:#C9973A;--gold-light:#F5E6C8;--dark:#1A1208;--bg:#FAF7F2;
    --card:#FFFFFF;--text:#2D2010;--muted:#7A6A55;--border:#E8DFD0;
    --red:#C0392B;--green:#27AE60;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
  .header{background:var(--dark);color:#fff;position:sticky;top:0;z-index:100;}
  .header-top{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid rgba(201,151,58,0.3);}
  .logo-area{display:flex;align-items:center;gap:12px;}
  .logo-circle{width:44px;height:44px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:var(--dark);}
  .restaurant-name{font-family:'Playfair Display',serif;font-size:18px;font-weight:600;color:#fff;}
  .restaurant-sub{font-size:11px;color:rgba(201,151,58,0.9);letter-spacing:1.5px;text-transform:uppercase;margin-top:1px;}
  .cart-btn{background:var(--gold);color:var(--dark);border:none;border-radius:22px;padding:8px 18px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;}
  .cart-btn .count{background:var(--dark);color:var(--gold);border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;}
  .tabs-wrap{background:var(--dark);padding:0 20px 0;}
  .tabs{display:flex;border-top:1px solid rgba(255,255,255,0.06);}
  .tab{flex:1;padding:12px 8px;text-align:center;font-size:12px;font-weight:600;color:rgba(255,255,255,0.45);letter-spacing:0.8px;text-transform:uppercase;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;}
  .tab.active{color:var(--gold);border-bottom-color:var(--gold);}
  .hero{background:linear-gradient(135deg,#1A1208 0%,#3D2B0F 60%,#5C3D14 100%);padding:24px 20px 20px;position:relative;overflow:hidden;}
  .hero::before{content:'';position:absolute;top:-30px;right:-30px;width:180px;height:180px;border-radius:50%;background:rgba(201,151,58,0.08);pointer-events:none;}
  .hero-inner{position:relative;z-index:1;}
  .hero-badges{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;}
  .badge{padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;letter-spacing:0.5px;}
  .badge-gold{background:rgba(201,151,58,0.2);color:var(--gold);border:1px solid rgba(201,151,58,0.4);}
  .badge-green{background:rgba(39,174,96,0.15);color:#4CD97B;border:1px solid rgba(39,174,96,0.3);}
  .hero-title{font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:#fff;line-height:1.2;margin-bottom:6px;}
  .hero-title span{color:var(--gold);}
  .hero-loc{color:rgba(255,255,255,0.6);font-size:13px;display:flex;align-items:center;gap:5px;margin-bottom:14px;}
  .hero-stats{display:flex;gap:20px;}
  .stat{display:flex;align-items:center;gap:5px;}
  .stat-val{font-size:14px;font-weight:600;color:#fff;}
  .stat-label{font-size:12px;color:rgba(255,255,255,0.5);}
  .star{color:var(--gold);font-size:14px;}
  .info-bar{display:flex;gap:16px;background:#fff;border-bottom:1px solid var(--border);padding:12px 20px;overflow-x:auto;scrollbar-width:none;}
  .info-bar::-webkit-scrollbar{display:none;}
  .info-item{display:flex;align-items:center;gap:6px;white-space:nowrap;font-size:12px;color:var(--muted);}
  .info-item strong{color:var(--text);}
  .search-wrap{padding:16px 20px;background:var(--bg);}
  .search-box{display:flex;align-items:center;gap:10px;background:#fff;border:1px solid var(--border);border-radius:12px;padding:10px 14px;}
  .search-box svg{flex-shrink:0;opacity:.4;}
  .search-box input{border:none;outline:none;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--text);background:transparent;flex:1;}
  .search-box input::placeholder{color:#B0A090;}
  .cats-wrap{padding:0 20px 16px;overflow-x:auto;scrollbar-width:none;}
  .cats-wrap::-webkit-scrollbar{display:none;}
  .cats{display:flex;gap:8px;width:max-content;}
  .cat{padding:7px 16px;border-radius:20px;font-size:13px;font-weight:500;background:#fff;border:1px solid var(--border);color:var(--muted);cursor:pointer;white-space:nowrap;transition:all .2s;}
  .cat.active,.cat:hover{background:var(--dark);color:var(--gold);border-color:var(--dark);}
  .section{padding:0 20px 24px;}
  .section-title{font-family:'Playfair Display',serif;font-size:20px;font-weight:600;color:var(--text);margin-bottom:4px;}
  .section-count{font-size:12px;color:var(--muted);margin-bottom:16px;}
  .menu-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:12px;display:flex;align-items:flex-start;gap:14px;position:relative;cursor:pointer;transition:box-shadow .2s;}
  .menu-card:hover{box-shadow:0 4px 20px rgba(0,0,0,0.08);}
  .item-info{flex:1;min-width:0;}
  .veg-dot{width:12px;height:12px;border-radius:50%;border:1.5px solid;display:inline-block;margin-right:6px;vertical-align:middle;flex-shrink:0;}
  .veg{border-color:var(--green);background:rgba(39,174,96,0.15);}
  .nonveg{border-color:var(--red);background:rgba(192,57,43,0.15);}
  .item-name{font-size:15px;font-weight:600;color:var(--text);margin-bottom:4px;display:flex;align-items:center;flex-wrap:wrap;gap:4px;}
  .bestseller{background:#FFF3CD;color:#856404;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;letter-spacing:0.3px;}
  .item-desc{font-size:12px;color:var(--muted);line-height:1.5;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
  .item-price{font-size:16px;font-weight:700;color:var(--text);}
  .item-price .currency{font-size:12px;font-weight:500;color:var(--muted);}
  .item-img-wrap{flex-shrink:0;position:relative;}
  .item-img-placeholder{width:90px;height:90px;border-radius:12px;background:linear-gradient(135deg,#F5E6C8,#EDD5A3);display:flex;align-items:center;justify-content:center;font-size:28px;}
  .add-btn{position:absolute;bottom:-10px;left:50%;transform:translateX(-50%);background:#fff;border:1.5px solid var(--gold);border-radius:20px;color:var(--gold);font-size:13px;font-weight:700;padding:4px 16px;cursor:pointer;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,0.1);transition:all .2s;}
  .add-btn:hover{background:var(--gold);color:#fff;}
  .qty-ctrl{position:absolute;bottom:-10px;left:50%;transform:translateX(-50%);display:flex;align-items:center;background:var(--gold);border-radius:20px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.1);}
  .qty-ctrl button{background:transparent;border:none;color:#fff;font-size:16px;font-weight:700;width:28px;height:28px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  .qty-ctrl span{color:#fff;font-size:13px;font-weight:700;min-width:20px;text-align:center;}
  .divider{height:8px;background:#F0EAE0;}
  /* CART FOOTER */
  .cart-footer{position:fixed;bottom:0;left:0;right:0;background:var(--dark);padding:14px 20px;align-items:center;justify-content:space-between;box-shadow:0 -4px 20px rgba(0,0,0,0.2);z-index:99;display:none;}
  .cart-footer.show{display:flex;}
  .cart-info{color:#fff;}
  .cart-items-count{font-size:12px;color:rgba(255,255,255,0.6);}
  .cart-total{font-size:18px;font-weight:700;color:#fff;}
  .cart-total .curr{font-size:13px;font-weight:400;color:rgba(255,255,255,0.7);}
  .checkout-btn{background:var(--gold);color:var(--dark);border:none;border-radius:12px;padding:12px 24px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;}
  /* TOAST */
  .toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--dark);color:#fff;padding:10px 20px;border-radius:12px;font-size:13px;font-weight:500;opacity:0;transition:all .3s;z-index:400;pointer-events:none;white-space:nowrap;}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
  /* BOTTOM SHEET */
  .overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:200;opacity:0;pointer-events:none;transition:opacity .3s;}
  .overlay.show{opacity:1;pointer-events:all;}
  .bottom-sheet{position:fixed;bottom:0;left:0;right:0;background:#fff;border-radius:20px 20px 0 0;z-index:201;transform:translateY(100%);transition:transform .35s cubic-bezier(.32,.72,0,1);max-height:92vh;display:flex;flex-direction:column;}
  .bottom-sheet.show{transform:translateY(0);}
  .sheet-drag{width:40px;height:4px;background:#E0D8CC;border-radius:2px;margin:10px auto 0;}
  .sheet-hero{height:200px;background:linear-gradient(135deg,#F5E6C8,#EDD5A3);display:flex;align-items:center;justify-content:center;font-size:72px;flex-shrink:0;position:relative;}
  .sheet-hero-badge{position:absolute;top:14px;left:14px;}
  .sheet-body{overflow-y:auto;flex:1;padding-bottom:100px;}
  .sheet-header{padding:20px 20px 16px;border-bottom:1px solid var(--border);}
  .sheet-name-row{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:8px;}
  .sheet-name{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--text);line-height:1.25;}
  .sheet-price{font-size:22px;font-weight:700;color:var(--text);white-space:nowrap;}
  .sheet-desc{font-size:13px;color:var(--muted);line-height:1.6;}
  .cust-group{padding:20px 20px 0;}
  .cust-group-title{font-size:15px;font-weight:700;color:var(--text);margin-bottom:3px;}
  .cust-group-sub{font-size:12px;color:var(--muted);margin-bottom:14px;}
  .cust-row{display:flex;align-items:center;justify-content:space-between;padding:14px 0;border-bottom:1px solid var(--border);}
  .cust-row:last-child{border-bottom:none;}
  .cust-label{font-size:14px;color:var(--text);}
  .cust-right{display:flex;flex-direction:column;align-items:flex-end;gap:4px;}
  .cust-price{font-size:13px;color:var(--muted);}
  .radio-btn{width:22px;height:22px;border-radius:50%;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;flex-shrink:0;}
  .radio-btn.selected{border-color:var(--green);background:var(--green);}
  .radio-btn.selected::after{content:'';width:8px;height:8px;border-radius:50%;background:#fff;}
  .check-btn{width:22px;height:22px;border-radius:5px;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;flex-shrink:0;}
  .check-btn.selected{border-color:var(--green);background:var(--green);}
  .check-btn.selected::after{content:'✓';color:#fff;font-size:13px;font-weight:700;line-height:1;}
  .sheet-footer{position:absolute;bottom:0;left:0;right:0;background:#fff;padding:14px 20px;border-top:1px solid var(--border);}
  .sheet-add-btn{width:100%;background:var(--green);color:#fff;border:none;border-radius:14px;padding:16px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;cursor:pointer;letter-spacing:0.5px;transition:opacity .2s;}
  .sheet-add-btn:hover{opacity:0.9;}
  .sheet-footer-inner{display:flex;align-items:center;gap:12px;}
  .sheet-qty-ctrl{display:flex;align-items:center;background:var(--dark);border-radius:10px;overflow:hidden;}
  .sheet-qty-ctrl button{background:transparent;border:none;color:#fff;font-size:18px;font-weight:700;width:36px;height:40px;cursor:pointer;}
  .sheet-qty-ctrl span{color:#fff;font-size:14px;font-weight:700;min-width:24px;text-align:center;}

  /* ===== TABLE MODAL ===== */
  .table-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:500;display:none;align-items:center;justify-content:center;padding:20px;}
  .table-modal-overlay.show{display:flex;}
  .table-modal{background:#fff;border-radius:20px;padding:28px 24px;width:100%;max-width:340px;text-align:center;}
  .table-modal-icon{font-size:40px;margin-bottom:12px;}
  .table-modal-title{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:var(--text);margin-bottom:6px;}
  .table-modal-sub{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.5;}
  .table-input{width:100%;border:2px solid var(--border);border-radius:12px;padding:14px 16px;font-family:'DM Sans',sans-serif;font-size:18px;font-weight:700;text-align:center;color:var(--text);outline:none;transition:border .2s;margin-bottom:16px;}
  .table-input:focus{border-color:var(--gold);}
  .table-confirm-btn{width:100%;background:var(--dark);color:#fff;border:none;border-radius:12px;padding:15px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:opacity .2s;}
  .table-confirm-btn:hover{opacity:0.9;}
  .table-confirm-btn svg{flex-shrink:0;}
  .table-cancel{margin-top:10px;font-size:13px;color:var(--muted);cursor:pointer;text-decoration:underline;}

  /* ===== SENDING STATE ===== */
  .sending-overlay{position:fixed;inset:0;background:rgba(255,255,255,0.92);z-index:600;display:none;align-items:center;justify-content:center;flex-direction:column;gap:16px;}
  .sending-overlay.show{display:flex;}
  .spinner{width:40px;height:40px;border:3px solid var(--border);border-top-color:var(--green);border-radius:50%;animation:spin .8s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .sending-text{font-size:15px;font-weight:600;color:var(--text);}

  @media(max-width:400px){
    .hero-title{font-size:22px;}
    .item-img-placeholder{width:75px;height:75px;}
    .sheet-hero{height:160px;font-size:56px;}
  }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-top">
    <div class="logo-area">
      <div class="logo-circle">CN</div>
      <div>
        <div class="restaurant-name">Chef Nishanth</div>
        <div class="restaurant-sub">Church Street, Bangalore</div>
      </div>
    </div>
    <button class="cart-btn" onclick="openTableModal()">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      Cart <span class="count" id="headerCount">0</span>
    </button>
  </div>
  <div class="tabs-wrap">
    <div class="tabs">
      <div class="tab active">Dine-In</div>
      <div class="tab">Takeaway</div>
      <div class="tab">Delivery</div>
    </div>
  </div>
</div>

<!-- HERO -->
<div class="hero">
  <div class="hero-inner">
    <div class="hero-badges">
      <span class="badge badge-gold">✦ Fine Dining</span>
      <span class="badge badge-green">● Open Now</span>
    </div>
    <div class="hero-title">Chef <span>Nishanth's</span><br/>Kitchen</div>
    <div class="hero-loc">
      <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
      Church Street, MG Road, Bangalore
    </div>
    <div class="hero-stats">
      <div class="stat"><span class="star">★</span><span class="stat-val">4.7</span><span class="stat-label">&nbsp;(386)</span></div>
      <div class="stat"><span class="stat-val">25–35</span><span class="stat-label">&nbsp;min</span></div>
      <div class="stat"><span class="stat-val">₹400</span><span class="stat-label">&nbsp;for two</span></div>
    </div>
  </div>
</div>

<!-- INFO BAR -->
<div class="info-bar">
  <div class="info-item">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    <span><strong>11am – 11pm</strong></span>
  </div>
  <div class="info-item">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
    <span><strong>Veg & Non-Veg</strong></span>
  </div>
  <div class="info-item">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    <span><strong>FSSAI Certified</strong></span>
  </div>
</div>

<!-- SEARCH -->
<div class="search-wrap">
  <div class="search-box">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" placeholder="Search dishes..." id="searchInput" oninput="filterMenu()"/>
  </div>
</div>

<!-- CATEGORIES -->
<div class="cats-wrap">
  <div class="cats">
    <div class="cat active" onclick="filterCat('all',this)">All</div>
    <div class="cat" onclick="filterCat('starters',this)">Starters</div>
    <div class="cat" onclick="filterCat('mains',this)">Mains</div>
    <div class="cat" onclick="filterCat('biryani',this)">Biryani</div>
    <div class="cat" onclick="filterCat('breads',this)">Breads</div>
    <div class="cat" onclick="filterCat('desserts',this)">Desserts</div>
    <div class="cat" onclick="filterCat('drinks',this)">Drinks</div>
  </div>
</div>

<div id="menuContainer"></div>

<!-- CART FOOTER -->
<div class="cart-footer" id="cartFooter">
  <div class="cart-info">
    <div class="cart-items-count" id="cartItemsCount">0 items</div>
    <div class="cart-total"><span class="curr">₹</span><span id="cartTotal">0</span></div>
  </div>
  <button class="checkout-btn" onclick="openTableModal()">
    View Cart
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- ITEM SHEET OVERLAY -->
<div class="overlay" id="overlay" onclick="closeSheet()"></div>

<!-- ITEM BOTTOM SHEET -->
<div class="bottom-sheet" id="bottomSheet">
  <div class="sheet-drag"></div>
  <div class="sheet-hero" id="sheetHero">🍛</div>
  <div class="sheet-body" id="sheetBody"></div>
  <div class="sheet-footer">
    <div class="sheet-footer-inner">
      <div class="sheet-qty-ctrl">
        <button onclick="sheetQtyChange(-1)">−</button>
        <span id="sheetQty">1</span>
        <button onclick="sheetQtyChange(1)">+</button>
      </div>
      <button class="sheet-add-btn" id="sheetAddBtn" onclick="addToCartFromSheet()">ADD TO CART — ₹0</button>
    </div>
  </div>
</div>

<!-- TABLE NUMBER MODAL -->
<div class="table-modal-overlay" id="tableModalOverlay">
  <div class="table-modal">
    <div class="table-modal-icon">🪑</div>
    <div class="table-modal-title">Which table are you at?</div>
    <div class="table-modal-sub">Enter your table number so Chef Nishanth knows where to bring your order.</div>
    <input class="table-input" type="text" id="tableNumberInput" placeholder="e.g. Table 5" maxlength="20"/>
    <button class="table-confirm-btn" onclick="confirmOrder()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
      Send Order via WhatsApp
    </button>
    <div class="table-cancel" onclick="closeTableModal()">Cancel</div>
  </div>
</div>

<!-- SENDING OVERLAY -->
<div class="sending-overlay" id="sendingOverlay">
  <div class="spinner"></div>
  <div class="sending-text">Sending your order...</div>
</div>

<script>
// ─── CONFIG ────────────────────────────────────────────────
const WHATSAPP_NUMBER = '917019743880';
// PASTE YOUR APPS SCRIPT WEB APP URL BELOW after deploying
const APPS_SCRIPT_URL = 'YOUR_APPS_SCRIPT_URL_HERE';
// ───────────────────────────────────────────────────────────

const menuData = [
  {
    cat:'starters', name:'Crispy Chicken Lollipop', type:'nonveg', price:320, bestseller:true,
    desc:'Tender chicken drumettes marinated in chef\'s signature spice blend, flash-fried to golden perfection. Served with a house-made sriracha mayo and pickled cucumber.',
    emoji:'🍗',
    customGroups:[{title:'Choose your heat',sub:'choose any 1 (required)',type:'radio',max:1,options:[{name:'Mild',extra:0},{name:'Medium',extra:0},{name:'Hot',extra:0},{name:'Extra Hot',extra:10}]}],
    addons:[{name:'Extra Sauce',extra:30},{name:'Double Portion',extra:180},{name:'Add Fries',extra:90}]
